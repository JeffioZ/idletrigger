# Auto-detect text files, force LF line endings for consistency across platforms.
*       text=auto

# Go source — always LF
*.go    text eol=lf

# Shell / script files
*.sh    text eol=lf
*.ps1   text eol=lf

# Markdown / docs — LF in repo, let Windows users checkout as-is
*.md    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Python
*.py    text eol=lf

# Binary files — don't mangle line endings
*.ico   binary
*.exe   binary
*.syso  binary
*.png   binary
*.jpg   binary
*.gz    binary
*.zip   binary
