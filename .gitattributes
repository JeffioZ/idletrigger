# Auto-detect text files, then pin important project files to stable line endings.
*       text=auto

# Source files
*.go    text eol=lf

# Scripts
*.ps1   text eol=lf
*.bat   text eol=crlf

# Project metadata / docs / config examples
*.md    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files: never normalize line endings.
*.ico   binary
*.exe   binary
*.syso  binary
*.png   binary
